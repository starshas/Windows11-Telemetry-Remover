{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.invalid/windows-telemetry-remover/spyware-db.schema.json",
  "title": "Windows Telemetry Remover Database",
  "type": "object",
  "required": [
    "schemaVersion",
    "databaseVersion",
    "name",
    "description",
    "items"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "databaseVersion": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "agentInstructions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/item"
      }
    }
  },
  "additionalProperties": true,
  "definitions": {
    "item": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "scope",
        "description",
        "exfiltration",
        "severity",
        "severityReason",
        "applicableWindowsEditions",
        "applicabilityNote",
        "threatProofUrl",
        "threatProofExactQuote",
        "fixProofUrl",
        "fixProofExactQuote",
        "downsides",
        "checkCommands",
        "checks",
        "disableActions",
        "enableActions"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "enum": [
            "user",
            "machine"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "deprecatedAfterWindowsBuild": {
          "type": "integer",
          "minimum": 1
        },
        "exfiltration": {
          "enum": [
            "yes",
            "possible",
            "no"
          ]
        },
        "severity": {
          "enum": [
            "urgent",
            "high",
            "medium",
            "low",
            "veryLow"
          ]
        },
        "severityReason": {
          "type": "string",
          "minLength": 1
        },
        "applicableWindowsEditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "applicabilityNote": {
          "type": "string"
        },
        "threatProofUrl": {
          "type": "string",
          "minLength": 1
        },
        "threatProofExactQuote": {
          "type": "string",
          "minLength": 1
        },
        "fixProofUrl": {
          "type": "string",
          "minLength": 1
        },
        "fixProofExactQuote": {
          "type": "string",
          "minLength": 1
        },
        "downsides": {
          "type": "string"
        },
        "checkCommands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/check"
          }
        },
        "disableActions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/action"
          }
        },
        "enableActions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/action"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "check": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type",
            "name"
          ],
          "properties": {
            "type": {
              "const": "serviceDisabled"
            },
            "name": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path",
            "name",
            "value"
          ],
          "properties": {
            "type": {
              "const": "registryDwordEquals"
            },
            "path": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "value": {
              "type": "integer"
            },
            "missingIsIssue": {
              "type": "boolean"
            },
            "blocking": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "taskPath",
            "taskName"
          ],
          "properties": {
            "type": {
              "const": "scheduledTaskDisabled"
            },
            "taskPath": {
              "type": "string"
            },
            "taskName": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "werDisabled"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "const": "registryKeyAbsent"
            },
            "path": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path",
            "name"
          ],
          "properties": {
            "type": {
              "const": "registryValueAbsent"
            },
            "path": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "tailoredExperiencesDisabled"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "name",
            "value"
          ],
          "properties": {
            "type": {
              "const": "mpPreferenceEquals"
            },
            "name": {
              "type": "string"
            },
            "value": {
              "type": [
                "integer",
                "boolean"
              ]
            }
          }
        }
      ]
    },
    "action": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type",
            "name"
          ],
          "properties": {
            "type": {
              "const": "disableService"
            },
            "name": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "name"
          ],
          "properties": {
            "type": {
              "const": "enableService"
            },
            "name": {
              "type": "string"
            },
            "startupType": {
              "enum": [
                "Automatic",
                "Manual"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path",
            "name",
            "value"
          ],
          "properties": {
            "type": {
              "const": "setRegistryDword"
            },
            "path": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "value": {
              "type": "integer"
            },
            "bestEffort": {
              "type": "boolean"
            },
            "requiresAdministrator": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "taskPath",
            "taskName"
          ],
          "properties": {
            "type": {
              "const": "disableScheduledTask"
            },
            "taskPath": {
              "type": "string"
            },
            "taskName": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "taskPath",
            "taskName"
          ],
          "properties": {
            "type": {
              "const": "enableScheduledTask"
            },
            "taskPath": {
              "type": "string"
            },
            "taskName": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "disableWer"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "enableWer"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "const": "removeRegistryKey"
            },
            "path": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path",
            "name"
          ],
          "properties": {
            "type": {
              "const": "removeRegistryValue"
            },
            "path": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "const": "createRegistryKey"
            },
            "path": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "name",
            "value"
          ],
          "properties": {
            "type": {
              "const": "setMpPreference"
            },
            "name": {
              "type": "string"
            },
            "value": {
              "type": [
                "integer",
                "boolean"
              ]
            }
          }
        }
      ]
    }
  }
}
